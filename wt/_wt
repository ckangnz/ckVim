#compdef wt
# ~/.vim/wt/_wt
# Zsh completion for the wt command.
# Install: fpath=("$HOME/.vim/wt" $fpath) in .zshrc (before compinit)

_wt_repo_names() {
    local repos_file="${HOME}/.wt/repos"
    [[ ! -f "$repos_file" ]] && return
    grep -v '^\s*#' "$repos_file" | grep -v '^\s*$' | awk '{print $1}'
}

_wt_repo_agent_names() {
    # Returns <repo>-<N> pairs (short form, no leading zeros) for tab completion
    local repos_file="${HOME}/.wt/repos"
    [[ ! -f "$repos_file" ]] && return
    grep -v '^\s*#' "$repos_file" | grep -v '^\s*$' | while read -r name agents_dir; do
        for d in "${agents_dir}"/agent-*(N); do
            [[ -d "$d" ]] || continue
            local num="${${d:t}#agent-}"
            local short=$((10#$num))   # strip leading zeros: 001 → 1
            echo "${name}-${short}"
        done
    done | sort -u
}

_wt() {
    local state line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*: :->args' \
        '(- *)'{--help,-h}'[Show help]'

    case "$state" in
        cmd)
            local commands=(
                'repo:Manage repo registry (new, rm, list)'
                'init:Clone repo into worktree structure'
                'convert:Convert existing repo to worktree structure'
                'new:Create agent worktree(s)'
                'rm:Remove an agent worktree'
                'list:List all worktrees'
                'sync:Pull master + rebase agent worktree(s)'
                'close:Close tmux window for a worktree'
                '--help:Show help'
            )
            # Also offer registered repo names for wt <repo> "title"
            local repo_completions=()
            local rname
            for rname in $(_wt_repo_names); do
                repo_completions+=("${rname}:Open next unused ${rname} worktree")
            done
            # And repo-num completions for wt <repo>-<num> "title"
            local agent_completions=()
            local aname
            for aname in $(_wt_repo_agent_names); do
                agent_completions+=("${aname}:Open specific worktree")
            done
            _describe 'command' commands
            _describe 'repo' repo_completions
            _describe 'repo-agent' agent_completions
            ;;
        args)
            case "${line[1]}" in
                repo)
                    case "${line[2]}" in
                        register)
                            case "${#line}" in
                                3) _message 'repo name' ;;
                                4) _directories ;;
                            esac
                            ;;
                        unregister)
                            local repos=($(_wt_repo_names))
                            _describe 'repo' repos
                            ;;
                        list) ;;
                        *)
                            local subcommands=(
                                'register:Register a repo'
                                'unregister:Unregister a repo'
                                'list:List repos'
                            )
                            _describe 'subcommand' subcommands
                            ;;
                    esac
                    ;;
                init)
                    case "${#line}" in
                        2) _message 'git URL' ;;
                        3) _directories ;;
                    esac
                    ;;
                convert)
                    _directories
                    ;;
                new)
                    case "${#line}" in
                        2)
                            local repos=($(_wt_repo_names))
                            _describe 'repo' repos
                            ;;
                        3)
                            _message 'count (number of worktrees to create)'
                            ;;
                    esac
                    ;;
                rm)
                    # Complete both repo names (rm all) and repo-num (rm one)
                    local repos=($(_wt_repo_names))
                    local agents=($(_wt_repo_agent_names))
                    _describe 'repo (remove all)' repos
                    _describe 'repo-agent (remove one)' agents
                    ;;
                list)
                    local repos=($(_wt_repo_names))
                    _describe 'repo (optional filter)' repos
                    ;;
                sync)
                    # Complete both repo names and repo-num pairs
                    local repos=($(_wt_repo_names))
                    local agents=($(_wt_repo_agent_names))
                    _describe 'repo' repos
                    _describe 'repo-agent' agents
                    ;;
                close)
                    local agents=($(_wt_repo_agent_names))
                    _describe 'repo-agent' agents
                    ;;
                *)
                    # wt <repo> "title" or wt <repo>-<num> "title"
                    # Second arg is a free-form title string
                    _message 'workspace title'
                    ;;
            esac
            ;;
    esac
}

_wt "$@"
